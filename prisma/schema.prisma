generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum Role {
  SUPER_ADMIN
  ADMIN
  TRAINER
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum GroupStatus {
  ACTIVE
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum LandingBlockType {
  HERO
  PROGRAMS
  SCHEDULES
  TRAINERS
  TESTIMONIALS
  GALLERY
  CTA
  FOOTER
}

enum CampaignType {
  EMAIL
  WHATSAPP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
}

// --- MODELOS PRINCIPALES (MULTI-TENANT) ---

model Academy {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  logo         String?
  primaryColor String?
  createdAt    DateTime        @default(now())

  users           User[]
  landingBlocks   LandingBlock[]
  landingMedia    LandingMedia[]
  landingSettings LandingSettings?

  leads       Lead[]
  students    Student[]
  trainers    Trainer[]
  groups      Group[]
  attendance  Attendance[]
  payments    Payment[]
  campaigns   Campaign[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- LANDING / CMS ---

model LandingBlock {
  id         String           @id @default(cuid())
  academyId  String
  academy    Academy          @relation(fields: [academyId], references: [id])
  type       LandingBlockType
  order      Int
  isActive   Boolean          @default(true)
  content    Json
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([academyId, type])
}

model LandingMedia {
  id         String   @id @default(cuid())
  academyId  String
  academy    Academy  @relation(fields: [academyId], references: [id])
  url        String
  alt        String?
  type       String
  createdAt  DateTime @default(now())

  @@index([academyId])
}

model LandingSettings {
  id             String   @id @default(cuid())
  academyId      String   @unique
  academy        Academy  @relation(fields: [academyId], references: [id])
  heroSettings   Json?
  seoSettings    Json?
  contactEmail   String?
  contactPhone   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- LEADS ---

model Lead {
  id                String      @id @default(cuid())
  academyId         String
  academy           Academy     @relation(fields: [academyId], references: [id])
  name              String
  parentName        String?
  phone             String
  email             String?
  childAge          Int?
  interestProgram   String?
  status            LeadStatus  @default(NEW)
  createdAt         DateTime    @default(now())
  convertedStudentId String?

  @@index([academyId, status])
}

// --- STUDENTS / TRAINERS / GROUPS ---

model Student {
  id          String         @id @default(cuid())
  academyId   String
  academy     Academy        @relation(fields: [academyId], references: [id])

  firstName   String
  lastName    String
  birthDate   DateTime?
  parentName  String?
  parentPhone String?
  parentEmail String?
  status      StudentStatus  @default(ACTIVE)
  notes       String?

  groups      StudentGroup[]
  payments    Payment[]
  attendance  Attendance[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([academyId, status])
}

model Trainer {
  id        String   @id @default(cuid())
  academyId String
  academy   Academy  @relation(fields: [academyId], references: [id])
  name      String
  phone     String?
  email     String?
  specialty String?
  bio       String?
  photo     String?

  groups    Group[]

  @@index([academyId])
}

model Group {
  id           String        @id @default(cuid())
  academyId    String
  academy      Academy       @relation(fields: [academyId], references: [id])
  name         String
  sportType    String
  minAge       Int
  maxAge       Int
  capacity     Int
  monthlyPrice Decimal
  status       GroupStatus   @default(ACTIVE)
  trainerId    String?
  trainer      Trainer?      @relation(fields: [trainerId], references: [id])

  students     StudentGroup[]
  schedules    Schedule[]

  @@index([academyId, status])
}

model StudentGroup {
  studentId String
  groupId   String
  startDate DateTime
  endDate   DateTime?

  student   Student @relation(fields: [studentId], references: [id])
  group     Group   @relation(fields: [groupId], references: [id])

  @@id([studentId, groupId, startDate])
}

model Schedule {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  dayOfWeek Int
  startTime DateTime
  endTime   DateTime

  @@index([groupId, dayOfWeek])
}

// --- ATTENDANCE ---

model Attendance {
  id        String           @id @default(cuid())
  academyId String
  academy   Academy          @relation(fields: [academyId], references: [id])
  studentId String
  groupId   String
  date      DateTime
  status    AttendanceStatus
  notes     String?

  student   Student          @relation(fields: [studentId], references: [id])
  group     Group            @relation(fields: [groupId], references: [id])

  @@index([academyId, date])
}

// --- PAYMENTS ---

model Payment {
  id        String        @id @default(cuid())
  academyId String
  academy   Academy       @relation(fields: [academyId], references: [id])
  studentId String
  student   Student       @relation(fields: [studentId], references: [id])

  month     Int
  year      Int
  amount    Decimal
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod?
  dueDate   DateTime
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([academyId, status])
}

// --- CAMPAIGNS ---

model Campaign {
  id            String          @id @default(cuid())
  academyId     String
  academy       Academy         @relation(fields: [academyId], references: [id])
  name          String
  type          CampaignType
  targetSegment Json
  scheduledAt   DateTime?
  status        CampaignStatus  @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  logs          CampaignLog[]

  @@index([academyId, status])
}

model CampaignLog {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  targetType  String
  targetId    String
  status      String
  error       String?
  createdAt   DateTime @default(now())

  @@index([campaignId])
}